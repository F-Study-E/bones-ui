{
  "name": "@bones-ui/react",
  "version": "0.1.0",
  "description": "Headless UI components for React with built-in accessibility",
  "keywords": [
    "react",
    "headless",
    "ui",
    "components",
    "accessibility",
    "a11y",
    "radix-alternative"
  ],
  "license": "MIT",
  "author": "ehdrjs4502",
  "homepage": "https://github.com/F-Study-E/bones-ui#readme",
  "bugs": {
    "url": "https://github.com/F-Study-E/bones-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/F-Study-E/bones-ui.git",
    "directory": "packages/react"
  },
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "biome check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@bones-ui/tsconfig": "workspace:*",
    "@bones-ui/tsup-config": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "happy-dom": "^15.11.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  }
}
